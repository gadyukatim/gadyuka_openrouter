# Copy to .env (and keep it out of git). Only OPENROUTER_API_KEY is required.

# Required to generate images. Get one at https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-...

# Optional — sane defaults shown.
# GADYUKA_MODEL=openai/gpt-image-2
# GADYUKA_DATA_DIR=~/.gadyuka_openrouter
# GADYUKA_OUTPUT_DIR=~/.gadyuka_openrouter/outputs
# GADYUKA_TIMEOUT_MS=300000
# GADYUKA_MAX_RETRIES=2
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
