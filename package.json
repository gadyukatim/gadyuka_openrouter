{
  "name": "gadyuka_openrouter",
  "version": "0.1.0",
  "description": "gadyuka_openrouter — MCP server for AI image generation via OpenRouter: any image model, cost tracking, caching, batches/chains, reference images.",
  "type": "module",
  "bin": {
    "gadyuka_openrouter": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "engines": {
    "node": ">=18.17"
  },
  "scripts": {
    "build": "tsc && chmod +x dist/index.js",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "test": "npm run build && node test/e2e.mjs",
    "test:live": "npm run build && node test/smoke.mjs"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "openrouter",
    "image-generation",
    "ai",
    "agents"
  ],
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
